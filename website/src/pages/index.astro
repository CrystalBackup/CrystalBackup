---
import Crystal from '../components/Crystal.astro';
import '../styles/site.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const gh = 'https://github.com/CrystalBackup/CrystalBackup';
const links = {
  gh,
  quality: `${base}/quality/`,
  specs: `${gh}/tree/main/spec`,
  requirements: `${gh}/blob/main/spec/00-requirements.md`,
  architecture: `${gh}/blob/main/spec/01-architecture.md`,
  security: `${gh}/blob/main/spec/03-security-and-tenancy.md`,
  adr: `${gh}/tree/main/spec/adr`,
  roadmap: `${gh}/blob/main/spec/90-roadmap.md`,
  license: `${gh}/blob/main/LICENSE`,
};

const differentiators = [
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 16 9 5 9-5"/></svg>',
    title: 'Two planes, one operator',
    body: 'Cluster disaster recovery for admins <em>and</em> self-service, off-platform backups for namespace users — the <code>ClusterIssuer</code>/<code>Issuer</code> split, applied to backups.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><rect x="4" y="10.5" width="16" height="10" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 7.7-1.5"/></svg>',
    title: 'No lock-in, ever',
    body: 'Backups are plain <strong>restic</strong> repositories. Read them anytime with upstream <code>restic</code> and your key — no proprietary catalog to hold you hostage.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.6 3.1 3 7 3s7-1.4 7-3V6"/><path d="M5 12v6c0 1.6 3.1 3 7 3 1 0 1.9-.1 2.7-.3"/><path d="M20 15v4h-4"/><path d="M20 19a4 4 0 0 0-7-2.6"/></svg>',
    title: 'DR straight from the repository',
    body: 'Point it at an existing bucket and it <strong>discovers what is restorable</strong> — no surviving cluster, no pre-existing resources required.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3 5 6v6c0 4.4 3 7.6 7 9 4-1.4 7-4.6 7-9V6l-7-3Z"/><path d="m9 12 2 2 3.5-3.8"/></svg>',
    title: 'Isolation that actually holds',
    body: 'A non-forgeable, <strong>server-side</strong> <code>namespace=</code> filter on the shared DR repo — or the tenant’s own bucket and key on the namespace plane.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="13.5" r="3.4"/><path d="M4 8.5h2.5L8 6.5h8l1.5 2H20a1 1 0 0 1 1 1V19a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5a1 1 0 0 1 1-1Z"/></svg>',
    title: 'Least data movement',
    body: 'Storage-aware snapshots (CephFS shallow copies, RBD copy-on-write) back up from a read-only point in time — no heavy clones, no app downtime.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M9.5 4.5a2 2 0 1 1 4 0V6H16a2 2 0 0 1 2 2v2.5h1.5a2 2 0 1 1 0 4H18V17a2 2 0 0 1-2 2h-2.5v-1.5a2 2 0 1 0-4 0V19H7a2 2 0 0 1-2-2v-2.5H3.5a2 2 0 1 1 0-4H5V8a2 2 0 0 1 2-2h2.5Z"/></svg>',
    title: 'Coexists, doesn’t replace',
    body: 'A distinct API group, namespace, credentials and repositories — it runs next to Velero (or anything) with zero interference.',
  },
];

const compareCols = ['Crystal Backup', 'Velero', 'K8up', 'VolSync', 'Kasten K10'];
const compareRows = [
  ['Open source', 'yes', 'yes', 'yes', 'yes', 'no'],
  ['Namespace-user self-service', 'yes', 'no', 'yes', 'partial', 'partial'],
  ['Per-namespace isolation', 'yes', 'no', 'partial', 'partial', 'partial'],
  ['Off-platform, user’s own bucket + key', 'yes', 'partial', 'yes', 'yes', 'no'],
  ['PVC data + manifests', 'yes', 'yes', 'no', 'no', 'yes'],
  ['DR from the repository alone', 'yes', 'partial', 'no', 'no', 'partial'],
  ['Reversibility (standard tool)', 'yes', 'partial', 'yes', 'yes', 'no'],
  ['Coexistence (stated goal)', 'yes', 'partial', 'partial', 'partial', 'partial'],
];

const milestones = [
  ['M0', 'Scaffolding — CRDs, CI (0-CVE images), test harness', 'done'],
  ['M1', 'Core engine & cluster disaster recovery', 'done', `${base}/reports/crucible-m1.html`],
  ['M2', 'Restore — self-service & admin', 'done', `${base}/reports/crucible-m2.html`],
  ['0.2.1', 'Hardening — full M0–M2 audit & fixes', 'patch', [['Check report', `${base}/reports/audit-m2.1.html`], ['Crucible M2.1', `${base}/reports/crucible-m2.1.html`]]],
  ['M3', 'Manifests & cluster-scoped DR', 'done', `${base}/reports/crucible-m3.html`],
  ['M4', 'Consistency hooks, verification & maintenance', 'here'],
  ['M5', 'Namespace plane, external sync & right-to-erasure', ''],
  ['M6', 'Observability hardening & production beta', ''],
  ['M7', 'CLI & browse UI', ''],
  ['M8', 'Immutable locations', ''],
  ['M9', 'Coexistence hardening & DR drills', ''],
];

const markLabel = { yes: 'Yes', partial: 'Partial', no: 'No' };
const title = 'Crystal Backup — Multi-tenant Kubernetes backup & restore';
const description =
  'An open-source Kubernetes backup operator: cluster disaster recovery for admins, self-service off-platform backups for namespace users. Plain restic repositories, no lock-in. Built in the open.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060912" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://crystalbackup.github.io/CrystalBackup/" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="orbs" aria-hidden="true"></div>

    <!-- ───────────────────────── nav ───────────────────────── -->
    <header class="nav">
      <a class="brand" href="#top" aria-label="Crystal Backup — home">
        <Crystal class="brand-mark" uid="nav" />
        <span class="brand-name">Crystal<span>Backup</span></span>
      </a>
      <nav class="nav-links">
        <a href="#why">Why</a>
        <a href="#how">How it works</a>
        <a href="#compare">Compare</a>
        <a href="#roadmap">Roadmap</a>
        <a href={links.quality}>Quality</a>
        <a class="btn btn-ghost btn-sm" href={links.gh} target="_blank" rel="noopener">
          <span class="star">★</span> Star on GitHub
        </a>
      </nav>
    </header>

    <main id="top">
      <!-- ───────────────────────── hero ───────────────────────── -->
      <section class="hero">
        <div class="hero-copy">
          <span class="pill">
            <span class="dot"></span> Building M4 · M3 shipped (v0.3.0)
          </span>
          <h1>
            Every namespace gets <span class="grad">its own backups.</span>
          </h1>
          <p class="lead">
            Crystal Backup is a Kubernetes backup operator with two audiences: <strong>cluster
            disaster recovery</strong> for platform admins, and <strong>self-service, off-platform
            backups</strong> for the people who actually own the workloads. Plain restic
            repositories. Real tenant isolation. No lock-in.
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href={links.specs} target="_blank" rel="noopener">
              Read the design →
            </a>
            <a class="btn btn-ghost" href={links.gh} target="_blank" rel="noopener">
              <span class="star">★</span> Watch the repo
            </a>
          </div>
          <ul class="hero-trust">
            <li>Apache-2.0</li>
            <li>restic-compatible</li>
            <li>0-CVE images (apko/Wolfi)</li>
            <li>Built in the open, with AI</li>
          </ul>
        </div>
        <div class="hero-art" aria-hidden="true">
          <div class="halo"></div>
          <Crystal class="hero-crystal" uid="hero" />
          <span class="tag tag-a">cluster plane · DR</span>
          <span class="tag tag-b">namespace plane · self-service</span>
        </div>
      </section>

      <!-- ───────────────────────── why ───────────────────────── -->
      <section id="why" class="section">
        <p class="eyebrow">The gap</p>
        <h2>Managed clusters back themselves up. Their tenants can’t.</h2>
        <div class="why-grid">
          <div class="why-card problem">
            <h3>Today</h3>
            <p>
              Platforms run <strong>one cluster-wide backup tool, admin-only</strong>, as a safety
              net. The teams who own the workloads get no self-service backup or restore, no
              visibility into what’s protected, and no way to keep a copy <strong>off-platform under
              their own key</strong>.
            </p>
          </div>
          <div class="why-card answer">
            <h3>With Crystal Backup</h3>
            <p>
              Namespace users back up and restore <strong>their own namespace</strong> — data
              <em>and</em> manifests — on demand. Admins keep <strong>cluster-wide DR</strong>. And
              it runs <strong>alongside</strong> your current tool: coexistence, not “rip and
              replace”.
            </p>
          </div>
        </div>
      </section>

      <!-- ─────────────────── differentiators ─────────────────── -->
      <section id="different" class="section">
        <p class="eyebrow">What makes it different</p>
        <h2>Opinionated where it counts</h2>
        <div class="cards">
          {
            differentiators.map((d) => (
              <article class="card">
                <span class="ico" set:html={d.icon} />
                <h3>{d.title}</h3>
                <p set:html={d.body} />
              </article>
            ))
          }
        </div>
      </section>

      <!-- ───────────────────── how it works ──────────────────── -->
      <section id="how" class="section">
        <p class="eyebrow">How it works</p>
        <h2>Two planes, one cascade, standard repositories</h2>
        <p class="section-lead">
          Every backup is a restic repository in object storage. Schedules fan out to backups, and
          backups run <strong>mover Jobs in the operator’s own namespace</strong> — never inside a
          tenant’s.
        </p>

        <div class="flow">
          <div class="lane">
            <span class="lane-tag admin">Cluster plane · admins</span>
            <div class="chips">
              <span class="chip">ClusterBackupSchedule</span>
              <span class="sep"></span>
              <span class="chip">ClusterBackup</span>
              <span class="sep"></span>
              <span class="chip accent">mover Job<small>crystal-backup-system</small></span>
              <span class="sep"></span>
              <span class="chip repo">Shared DR repo<small>server-side <code>namespace=</code> filter</small></span>
            </div>
          </div>

          <div class="lane">
            <span class="lane-tag user">Namespace plane · users</span>
            <div class="chips">
              <span class="chip">BackupSchedule</span>
              <span class="sep"></span>
              <span class="chip">Backup</span>
              <span class="sep"></span>
              <span class="chip accent">mover Job<small>crystal-backup-system</small></span>
              <span class="sep"></span>
              <span class="chip repo">Your bucket + key<small>off-platform, own encryption</small></span>
            </div>
          </div>
        </div>

        <p class="flow-note">
          A snapshot taken in a tenant namespace is mounted <strong>centrally</strong> — the
          cluster-scoped <code>VolumeSnapshotContent</code> is re-bound into the operator namespace,
          so tenant data is never exposed to a neighbour. Every repository is standard restic; a
          second location can be kept in sync, re-encrypted to its <strong>own</strong> key.
        </p>
      </section>

      <!-- ─────────────────────── compare ─────────────────────── -->
      <section id="compare" class="section">
        <p class="eyebrow">How it compares</p>
        <h2>Where Crystal Backup aims</h2>
        <p class="section-lead">
          Early-stage <strong>targets</strong> vs the <strong>current</strong> capabilities of
          established tools, to our knowledge — different projects, different goals, not a benchmark.
        </p>

        <div class="table-wrap">
          <table class="compare">
            <thead>
              <tr>
                <th class="cap">Capability</th>
                {
                  compareCols.map((c, i) => (
                    <th class={i === 0 ? 'ours' : ''}>{c}{i === 0 && <small>target</small>}</th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                compareRows.map((row) => (
                  <tr>
                    <td class="cap">{row[0]}</td>
                    {
                      row.slice(1).map((v, i) => (
                        <td class={i === 0 ? 'ours' : ''}>
                          <span class={`mark ${v}`} title={markLabel[v]}>
                            <span class="sr">{markLabel[v]}</span>
                          </span>
                        </td>
                      ))
                    }
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="legend">
          <span class="mark yes"></span> Yes
          <span class="mark partial"></span> Partial / conditional
          <span class="mark no"></span> No
        </p>
      </section>

      <!-- ─────────────────────── roadmap ─────────────────────── -->
      <section id="roadmap" class="section">
        <p class="eyebrow">Roadmap</p>
        <h2>Releasable, core-first, in the open</h2>
        <p class="section-lead">
          Each milestone ships something usable. <strong>M0 through M3 have shipped</strong> — CRDs,
          CI, the core engine, cluster disaster recovery, self-service &amp; admin restore and
          manifest &amp; cluster-scoped DR are live (v0.3.0); we’re now building
          <strong>M4 — Consistency hooks, verification &amp; maintenance</strong>.
        </p>
        <ol class="timeline">
          {
            milestones.map(([id, label, state, report]) => (
              <li class={state}>
                <span class="ms-id">{id}</span>
                <span class="ms-label">{label}</span>
                <span class="ms-actions">
                  {state === 'here' && <span class="ms-here">you are here</span>}
                  {state === 'done' && !report && <span class="ms-done">done</span>}
                  {report && (Array.isArray(report)
                    ? report.map(([lbl, href]) => (
                        <a class="ms-report" href={href} target="_blank" rel="noopener">{lbl}</a>
                      ))
                    : <a class="ms-report" href={report} target="_blank" rel="noopener">Crucible report</a>
                  )}
                </span>
              </li>
            ))
          }
        </ol>
        <p class="section-foot">
          Full breakdown in <a href={links.roadmap} target="_blank" rel="noopener">the roadmap</a>.
        </p>
      </section>

      <!-- ───────────────────── open / honest ─────────────────── -->
      <section id="open" class="section">
        <div class="open-card">
          <div>
            <p class="eyebrow">Built in the open, with AI</p>
            <h2>You can read every decision.</h2>
            <p class="section-lead">
              Crystal Backup is as much an experiment in <strong>AI-assisted engineering</strong> as
              it is a backup tool. Specs, decision records and code are produced with AI
              assistants under human review — every requirement and trade-off is written down and
              public. You get to watch the reasoning, not just the result.
            </p>
          </div>
          <aside class="note">
            <h3>You’re early — and that’s the point</h3>
            <p>
              M0 through M3 have shipped (v0.3.0) — real, tested code — but it’s still early: most
              milestones are ahead and it isn’t production-ready yet, so try it in a sandbox, keep
              your existing backups, and use it at your own risk. It’s
              provided <strong>as-is under Apache-2.0</strong>, without warranty. If the direction
              speaks to you, <a href={links.gh} target="_blank" rel="noopener">star or watch the
              repo</a> and follow along.
            </p>
          </aside>
        </div>
      </section>

      <!-- ───────────────────────── cta ───────────────────────── -->
      <section class="cta">
        <h2>Follow the build</h2>
        <p>The specifications, 16 decision records and self-service &amp; admin restore (v0.2.1) are public. Manifests &amp; cluster-scoped DR are next.</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={links.gh} target="_blank" rel="noopener">
            <span class="star">★</span> Star / watch on GitHub
          </a>
          <a class="btn btn-ghost" href={links.requirements} target="_blank" rel="noopener">
            Read the requirements →
          </a>
        </div>
      </section>
    </main>

    <!-- ───────────────────────── footer ────────────────────── -->
    <footer class="footer">
      <div class="foot-brand">
        <Crystal class="brand-mark" uid="foot" />
        <span class="brand-name">Crystal<span>Backup</span></span>
      </div>
      <nav class="foot-links">
        <a href={links.requirements} target="_blank" rel="noopener">Requirements</a>
        <a href={links.architecture} target="_blank" rel="noopener">Architecture</a>
        <a href={links.security} target="_blank" rel="noopener">Security &amp; tenancy</a>
        <a href={links.adr} target="_blank" rel="noopener">Decision records</a>
        <a href={links.roadmap} target="_blank" rel="noopener">Roadmap</a>
        <a href={links.quality}>Quality &amp; testing</a>
        <a href={links.license} target="_blank" rel="noopener">License</a>
        <a href={links.gh} target="_blank" rel="noopener">GitHub</a>
      </nav>
      <p class="foot-fine">
        Apache-2.0 · built in the open with AI assistance · provided as-is, without warranty — use
        it at your own risk.
      </p>
    </footer>

  </body>
</html>
