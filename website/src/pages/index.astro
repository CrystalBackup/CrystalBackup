---
import Crystal from '../components/Crystal.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const gh = 'https://github.com/CrystalBackup/CrystalBackup';
const links = {
  gh,
  specs: `${gh}/tree/main/spec`,
  requirements: `${gh}/blob/main/spec/00-requirements.md`,
  architecture: `${gh}/blob/main/spec/01-architecture.md`,
  security: `${gh}/blob/main/spec/03-security-and-tenancy.md`,
  adr: `${gh}/tree/main/spec/adr`,
  roadmap: `${gh}/blob/main/spec/90-roadmap.md`,
  license: `${gh}/blob/main/LICENSE`,
};

const differentiators = [
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 16 9 5 9-5"/></svg>',
    title: 'Two planes, one operator',
    body: 'Cluster disaster recovery for admins <em>and</em> self-service, off-platform backups for namespace users — the <code>ClusterIssuer</code>/<code>Issuer</code> split, applied to backups.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><rect x="4" y="10.5" width="16" height="10" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 7.7-1.5"/></svg>',
    title: 'No lock-in, ever',
    body: 'Backups are plain <strong>restic</strong> repositories. Read them anytime with upstream <code>restic</code> and your key — no proprietary catalog to hold you hostage.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.6 3.1 3 7 3s7-1.4 7-3V6"/><path d="M5 12v6c0 1.6 3.1 3 7 3 1 0 1.9-.1 2.7-.3"/><path d="M20 15v4h-4"/><path d="M20 19a4 4 0 0 0-7-2.6"/></svg>',
    title: 'DR straight from the repository',
    body: 'Point it at an existing bucket and it <strong>discovers what is restorable</strong> — no surviving cluster, no pre-existing resources required.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M12 3 5 6v6c0 4.4 3 7.6 7 9 4-1.4 7-4.6 7-9V6l-7-3Z"/><path d="m9 12 2 2 3.5-3.8"/></svg>',
    title: 'Isolation that actually holds',
    body: 'A non-forgeable, <strong>server-side</strong> <code>namespace=</code> filter on the shared DR repo — or the tenant’s own bucket and key on the namespace plane.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="13.5" r="3.4"/><path d="M4 8.5h2.5L8 6.5h8l1.5 2H20a1 1 0 0 1 1 1V19a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5a1 1 0 0 1 1-1Z"/></svg>',
    title: 'Least data movement',
    body: 'Storage-aware snapshots (CephFS shallow copies, RBD copy-on-write) back up from a read-only point in time — no heavy clones, no app downtime.',
  },
  {
    icon: '<svg viewBox="0 0 24 24"><path d="M9.5 4.5a2 2 0 1 1 4 0V6H16a2 2 0 0 1 2 2v2.5h1.5a2 2 0 1 1 0 4H18V17a2 2 0 0 1-2 2h-2.5v-1.5a2 2 0 1 0-4 0V19H7a2 2 0 0 1-2-2v-2.5H3.5a2 2 0 1 1 0-4H5V8a2 2 0 0 1 2-2h2.5Z"/></svg>',
    title: 'Coexists, doesn’t replace',
    body: 'A distinct API group, namespace, credentials and repositories — it runs next to Velero (or anything) with zero interference.',
  },
];

const compareCols = ['Crystal Backup', 'Velero', 'K8up', 'VolSync', 'Kasten K10'];
const compareRows = [
  ['Open source', 'yes', 'yes', 'yes', 'yes', 'no'],
  ['Namespace-user self-service', 'yes', 'no', 'yes', 'partial', 'partial'],
  ['Per-namespace isolation', 'yes', 'no', 'partial', 'partial', 'partial'],
  ['Off-platform, user’s own bucket + key', 'yes', 'partial', 'yes', 'yes', 'no'],
  ['PVC data + manifests', 'yes', 'yes', 'no', 'no', 'yes'],
  ['DR from the repository alone', 'yes', 'partial', 'no', 'no', 'partial'],
  ['Reversibility (standard tool)', 'yes', 'partial', 'yes', 'yes', 'no'],
  ['Coexistence (stated goal)', 'yes', 'partial', 'partial', 'partial', 'partial'],
];

const milestones = [
  ['M0', 'Scaffolding — CRDs, CI (0-CVE images), test harness', true],
  ['M1', 'Core engine & cluster disaster recovery', false],
  ['M2', 'Restore — self-service & admin', false],
  ['M3', 'Manifests & cluster-scoped DR', false],
  ['M4', 'Consistency hooks, verification & maintenance', false],
  ['M5', 'Namespace plane, external sync & right-to-erasure', false],
  ['M6', 'Observability hardening & production beta', false],
  ['M7', 'CLI & browse UI', false],
  ['M8', 'Immutable locations', false],
  ['M9', 'Coexistence hardening & DR drills', false],
];

const markLabel = { yes: 'Yes', partial: 'Partial', no: 'No' };
const title = 'Crystal Backup — Multi-tenant Kubernetes backup & restore';
const description =
  'An open-source Kubernetes backup operator: cluster disaster recovery for admins, self-service off-platform backups for namespace users. Plain restic repositories, no lock-in. Built in the open.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060912" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://crystalbackup.github.io/CrystalBackup/" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="orbs" aria-hidden="true"></div>

    <!-- ───────────────────────── nav ───────────────────────── -->
    <header class="nav">
      <a class="brand" href="#top" aria-label="Crystal Backup — home">
        <Crystal class="brand-mark" uid="nav" />
        <span class="brand-name">Crystal<span>Backup</span></span>
      </a>
      <nav class="nav-links">
        <a href="#why">Why</a>
        <a href="#how">How it works</a>
        <a href="#compare">Compare</a>
        <a href="#roadmap">Roadmap</a>
        <a class="btn btn-ghost btn-sm" href={links.gh} target="_blank" rel="noopener">
          <span class="star">★</span> Star on GitHub
        </a>
      </nav>
    </header>

    <main id="top">
      <!-- ───────────────────────── hero ───────────────────────── -->
      <section class="hero">
        <div class="hero-copy">
          <span class="pill">
            <span class="dot"></span> Open-design phase · milestone M0
          </span>
          <h1>
            Every namespace gets <span class="grad">its own backups.</span>
          </h1>
          <p class="lead">
            Crystal Backup is a Kubernetes backup operator with two audiences: <strong>cluster
            disaster recovery</strong> for platform admins, and <strong>self-service, off-platform
            backups</strong> for the people who actually own the workloads. Plain restic
            repositories. Real tenant isolation. No lock-in.
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href={links.specs} target="_blank" rel="noopener">
              Read the design →
            </a>
            <a class="btn btn-ghost" href={links.gh} target="_blank" rel="noopener">
              <span class="star">★</span> Watch the repo
            </a>
          </div>
          <ul class="hero-trust">
            <li>Apache-2.0</li>
            <li>restic-compatible</li>
            <li>0-CVE images (apko/Wolfi)</li>
            <li>Built in the open, with AI</li>
          </ul>
        </div>
        <div class="hero-art" aria-hidden="true">
          <div class="halo"></div>
          <Crystal class="hero-crystal" uid="hero" />
          <span class="tag tag-a">cluster plane · DR</span>
          <span class="tag tag-b">namespace plane · self-service</span>
        </div>
      </section>

      <!-- ───────────────────────── why ───────────────────────── -->
      <section id="why" class="section">
        <p class="eyebrow">The gap</p>
        <h2>Managed clusters back themselves up. Their tenants can’t.</h2>
        <div class="why-grid">
          <div class="why-card problem">
            <h3>Today</h3>
            <p>
              Platforms run <strong>one cluster-wide backup tool, admin-only</strong>, as a safety
              net. The teams who own the workloads get no self-service backup or restore, no
              visibility into what’s protected, and no way to keep a copy <strong>off-platform under
              their own key</strong>.
            </p>
          </div>
          <div class="why-card answer">
            <h3>With Crystal Backup</h3>
            <p>
              Namespace users back up and restore <strong>their own namespace</strong> — data
              <em>and</em> manifests — on demand. Admins keep <strong>cluster-wide DR</strong>. And
              it runs <strong>alongside</strong> your current tool: coexistence, not “rip and
              replace”.
            </p>
          </div>
        </div>
      </section>

      <!-- ─────────────────── differentiators ─────────────────── -->
      <section id="different" class="section">
        <p class="eyebrow">What makes it different</p>
        <h2>Opinionated where it counts</h2>
        <div class="cards">
          {
            differentiators.map((d) => (
              <article class="card">
                <span class="ico" set:html={d.icon} />
                <h3>{d.title}</h3>
                <p set:html={d.body} />
              </article>
            ))
          }
        </div>
      </section>

      <!-- ───────────────────── how it works ──────────────────── -->
      <section id="how" class="section">
        <p class="eyebrow">How it works</p>
        <h2>Two planes, one cascade, standard repositories</h2>
        <p class="section-lead">
          Every backup is a restic repository in object storage. Schedules fan out to backups, and
          backups run <strong>mover Jobs in the operator’s own namespace</strong> — never inside a
          tenant’s.
        </p>

        <div class="flow">
          <div class="lane">
            <span class="lane-tag admin">Cluster plane · admins</span>
            <div class="chips">
              <span class="chip">ClusterBackupSchedule</span>
              <span class="sep"></span>
              <span class="chip">ClusterBackup</span>
              <span class="sep"></span>
              <span class="chip accent">mover Job<small>crystal-backup-system</small></span>
              <span class="sep"></span>
              <span class="chip repo">Shared DR repo<small>server-side <code>namespace=</code> filter</small></span>
            </div>
          </div>

          <div class="lane">
            <span class="lane-tag user">Namespace plane · users</span>
            <div class="chips">
              <span class="chip">BackupSchedule</span>
              <span class="sep"></span>
              <span class="chip">Backup</span>
              <span class="sep"></span>
              <span class="chip accent">mover Job<small>crystal-backup-system</small></span>
              <span class="sep"></span>
              <span class="chip repo">Your bucket + key<small>off-platform, own encryption</small></span>
            </div>
          </div>
        </div>

        <p class="flow-note">
          A snapshot taken in a tenant namespace is mounted <strong>centrally</strong> — the
          cluster-scoped <code>VolumeSnapshotContent</code> is re-bound into the operator namespace,
          so tenant data is never exposed to a neighbour. Every repository is standard restic; a
          second location can be kept in sync, re-encrypted to its <strong>own</strong> key.
        </p>
      </section>

      <!-- ─────────────────────── compare ─────────────────────── -->
      <section id="compare" class="section">
        <p class="eyebrow">How it compares</p>
        <h2>Where Crystal Backup aims</h2>
        <p class="section-lead">
          Design-stage <strong>targets</strong> vs the <strong>current</strong> capabilities of
          established tools, to our knowledge — different projects, different goals, not a benchmark.
        </p>

        <div class="table-wrap">
          <table class="compare">
            <thead>
              <tr>
                <th class="cap">Capability</th>
                {
                  compareCols.map((c, i) => (
                    <th class={i === 0 ? 'ours' : ''}>{c}{i === 0 && <small>target</small>}</th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                compareRows.map((row) => (
                  <tr>
                    <td class="cap">{row[0]}</td>
                    {
                      row.slice(1).map((v, i) => (
                        <td class={i === 0 ? 'ours' : ''}>
                          <span class={`mark ${v}`} title={markLabel[v]}>
                            <span class="sr">{markLabel[v]}</span>
                          </span>
                        </td>
                      ))
                    }
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="legend">
          <span class="mark yes"></span> Yes
          <span class="mark partial"></span> Partial / conditional
          <span class="mark no"></span> No
        </p>
      </section>

      <!-- ─────────────────────── roadmap ─────────────────────── -->
      <section id="roadmap" class="section">
        <p class="eyebrow">Roadmap</p>
        <h2>Releasable, core-first, in the open</h2>
        <p class="section-lead">
          Each milestone ships something usable. Today we’re at <strong>M0 — not started</strong>:
          the design is what’s public.
        </p>
        <ol class="timeline">
          {
            milestones.map(([id, label, here]) => (
              <li class={here ? 'here' : ''}>
                <span class="ms-id">{id}</span>
                <span class="ms-label">{label}</span>
                {here && <span class="ms-here">you are here</span>}
              </li>
            ))
          }
        </ol>
        <p class="section-foot">
          Full breakdown in <a href={links.roadmap} target="_blank" rel="noopener">the roadmap</a>.
        </p>
      </section>

      <!-- ───────────────────── open / honest ─────────────────── -->
      <section id="open" class="section">
        <div class="open-card">
          <div>
            <p class="eyebrow">Built in the open, with AI</p>
            <h2>You can read every decision.</h2>
            <p class="section-lead">
              Crystal Backup is as much an experiment in <strong>AI-assisted engineering</strong> as
              it is a backup tool. Specs, decision records and the code to come are produced with AI
              assistants under human review — every requirement and trade-off is written down and
              public. You get to watch the reasoning, not just the result.
            </p>
          </div>
          <aside class="note">
            <h3>You’re early — and that’s the point</h3>
            <p>
              This is the open-design phase; code starts at M0. It isn’t production-ready yet, so
              try it in a sandbox, keep your existing backups, and use it at your own risk. It’s
              provided <strong>as-is under Apache-2.0</strong>, without warranty. If the direction
              speaks to you, <a href={links.gh} target="_blank" rel="noopener">star or watch the
              repo</a> and follow along.
            </p>
          </aside>
        </div>
      </section>

      <!-- ───────────────────────── cta ───────────────────────── -->
      <section class="cta">
        <h2>Follow the build</h2>
        <p>The specifications and 13 decision records are public. Code is next.</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={links.gh} target="_blank" rel="noopener">
            <span class="star">★</span> Star / watch on GitHub
          </a>
          <a class="btn btn-ghost" href={links.requirements} target="_blank" rel="noopener">
            Read the requirements →
          </a>
        </div>
      </section>
    </main>

    <!-- ───────────────────────── footer ────────────────────── -->
    <footer class="footer">
      <div class="foot-brand">
        <Crystal class="brand-mark" uid="foot" />
        <span class="brand-name">Crystal<span>Backup</span></span>
      </div>
      <nav class="foot-links">
        <a href={links.requirements} target="_blank" rel="noopener">Requirements</a>
        <a href={links.architecture} target="_blank" rel="noopener">Architecture</a>
        <a href={links.security} target="_blank" rel="noopener">Security &amp; tenancy</a>
        <a href={links.adr} target="_blank" rel="noopener">Decision records</a>
        <a href={links.roadmap} target="_blank" rel="noopener">Roadmap</a>
        <a href={links.license} target="_blank" rel="noopener">License</a>
        <a href={links.gh} target="_blank" rel="noopener">GitHub</a>
      </nav>
      <p class="foot-fine">
        Apache-2.0 · built in the open with AI assistance · provided as-is, without warranty — use
        it at your own risk.
      </p>
    </footer>

    <style is:global>
      :root {
        --bg: #060912;
        --bg-2: #0a1020;
        --panel: rgba(255, 255, 255, 0.035);
        --panel-2: rgba(255, 255, 255, 0.055);
        --brd: rgba(255, 255, 255, 0.09);
        --brd-2: rgba(255, 255, 255, 0.16);
        --ice: #cdeeff;
        --cyan: #3fc8f5;
        --azure: #3b8cff;
        --blue: #2b63f0;
        --text: #e9f0ff;
        --muted: #9aabce;
        --muted-2: #6f7fa6;
        --grad: linear-gradient(135deg, #3fc8f5, #2b63f0);
        --ok: #57d6a8;
        --warn: #f2c14e;
        --no: #7d8bb0;
        --radius: 16px;
        --maxw: 1120px;
        --pad: clamp(20px, 5vw, 40px);
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      a { color: inherit; }

      code {
        font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, Consolas, monospace;
        font-size: 0.86em;
        background: rgba(63, 200, 245, 0.1);
        border: 1px solid rgba(63, 200, 245, 0.16);
        padding: 0.08em 0.4em;
        border-radius: 6px;
        color: #b9e8fb;
      }

      /* background glow */
      .orbs {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(900px 600px at 78% -8%, rgba(43, 99, 240, 0.22), transparent 60%),
          radial-gradient(700px 520px at 8% 4%, rgba(63, 200, 245, 0.14), transparent 58%),
          radial-gradient(1000px 700px at 50% 108%, rgba(43, 99, 240, 0.12), transparent 60%),
          linear-gradient(180deg, var(--bg), var(--bg-2));
      }

      h1, h2, h3 { line-height: 1.12; letter-spacing: -0.02em; margin: 0; }

      .grad {
        background: var(--grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      /* ── layout ── */
      main { display: block; }

      .section {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(56px, 9vw, 104px) var(--pad) 0;
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--cyan);
        margin: 0 0 14px;
      }

      .section > h2 {
        font-size: clamp(1.7rem, 3.4vw, 2.5rem);
        font-weight: 800;
        max-width: 18ch;
      }

      .section-lead {
        color: var(--muted);
        max-width: 62ch;
        font-size: 1.06rem;
        margin: 18px 0 0;
      }

      /* ── nav ── */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 14px var(--pad);
        background: rgba(6, 9, 18, 0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid transparent;
      }
      .brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
      .brand-mark { width: 22px; height: 37px; display: block; filter: drop-shadow(0 3px 10px rgba(43, 99, 240, 0.5)); }
      .brand-name { font-weight: 800; letter-spacing: -0.01em; font-size: 1.06rem; }
      .brand-name span { color: var(--cyan); }
      .nav-links { display: flex; align-items: center; gap: 26px; }
      .nav-links > a:not(.btn) {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.15s;
      }
      .nav-links > a:not(.btn):hover { color: var(--text); }

      /* ── buttons ── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        font-weight: 650;
        font-size: 0.98rem;
        padding: 12px 20px;
        border-radius: 12px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s, border-color 0.2s;
        white-space: nowrap;
      }
      .btn-sm { padding: 8px 14px; font-size: 0.9rem; border-radius: 10px; }
      .btn-primary {
        background: var(--grad);
        color: #041027;
        box-shadow: 0 10px 30px -10px rgba(43, 99, 240, 0.7);
      }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 16px 40px -12px rgba(63, 200, 245, 0.7); }
      .btn-ghost { background: var(--panel); border-color: var(--brd-2); color: var(--text); }
      .btn-ghost:hover { transform: translateY(-2px); background: var(--panel-2); border-color: var(--cyan); }
      .star { color: var(--warn); }
      .btn-primary .star { color: #7a4f00; }

      /* ── hero ── */
      .hero {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(48px, 8vw, 96px) var(--pad) clamp(24px, 4vw, 40px);
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: clamp(24px, 5vw, 56px);
        align-items: center;
      }
      .hero-copy h1 {
        font-size: clamp(2.4rem, 6vw, 4rem);
        font-weight: 850;
        margin: 20px 0 0;
      }
      .lead { color: var(--muted); font-size: clamp(1.05rem, 1.6vw, 1.22rem); margin: 22px 0 0; max-width: 54ch; }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #c7d6f5;
        background: var(--panel);
        border: 1px solid var(--brd);
        padding: 7px 14px;
        border-radius: 999px;
      }
      .pill .dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--cyan);
        box-shadow: 0 0 0 4px rgba(63, 200, 245, 0.18);
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
      .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
      .hero-trust {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 10px 22px;
        padding: 0;
        margin: 30px 0 0;
        color: var(--muted-2);
        font-size: 0.86rem;
        font-weight: 500;
      }
      .hero-trust li { position: relative; padding-left: 18px; }
      .hero-trust li::before {
        content: '';
        position: absolute; left: 0; top: 50%; transform: translateY(-50%);
        width: 7px; height: 7px; border-radius: 2px; background: var(--grad);
      }

      /* hero art */
      .hero-art { position: relative; display: grid; place-items: center; min-height: 340px; }
      .hero-crystal {
        width: clamp(150px, 22vw, 220px);
        height: auto;
        filter: drop-shadow(0 24px 60px rgba(43, 99, 240, 0.55));
        animation: float 6s ease-in-out infinite;
      }
      @keyframes float { 0%, 100% { transform: translateY(-8px); } 50% { transform: translateY(8px); } }
      .halo {
        position: absolute;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(63, 200, 245, 0.32), rgba(43, 99, 240, 0.12) 45%, transparent 70%);
        filter: blur(8px);
      }
      .tag {
        position: absolute;
        font-size: 0.76rem;
        font-weight: 600;
        color: #cfe0ff;
        background: rgba(10, 16, 32, 0.72);
        border: 1px solid var(--brd-2);
        padding: 6px 12px;
        border-radius: 999px;
        backdrop-filter: blur(6px);
        white-space: nowrap;
      }
      .tag-a { top: 20%; left: -6%; }
      .tag-b { bottom: 18%; right: -10%; }

      /* ── why ── */
      .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 34px; }
      .why-card { border-radius: var(--radius); padding: 26px; border: 1px solid var(--brd); background: var(--panel); }
      .why-card h3 { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; }
      .why-card.problem { border-left: 3px solid var(--muted-2); }
      .why-card.problem h3 { color: var(--muted); }
      .why-card.answer { border-left: 3px solid var(--cyan); background: linear-gradient(180deg, rgba(63, 200, 245, 0.06), var(--panel)); }
      .why-card.answer h3 { color: var(--cyan); }
      .why-card p { margin: 0; color: var(--muted); }
      .why-card strong { color: var(--text); font-weight: 650; }

      /* ── cards ── */
      .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
      .card {
        border-radius: var(--radius);
        padding: 26px;
        background: var(--panel);
        border: 1px solid var(--brd);
        transition: transform 0.18s ease, border-color 0.18s, background 0.18s;
      }
      .card:hover { transform: translateY(-4px); border-color: var(--brd-2); background: var(--panel-2); }
      .ico {
        display: inline-grid;
        place-items: center;
        width: 46px; height: 46px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(63, 200, 245, 0.16), rgba(43, 99, 240, 0.16));
        border: 1px solid var(--brd-2);
        margin-bottom: 16px;
      }
      .ico :global(svg) { width: 24px; height: 24px; fill: none; stroke: var(--cyan); stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
      .card h3 { font-size: 1.14rem; font-weight: 700; margin-bottom: 8px; }
      .card p { margin: 0; color: var(--muted); font-size: 0.97rem; }
      .card strong { color: var(--text); font-weight: 650; }
      .card em { color: #d6e2ff; font-style: normal; font-weight: 600; }

      /* ── flow / how ── */
      .flow { margin-top: 42px; display: grid; gap: 18px; }
      .lane {
        border: 1px solid var(--brd);
        background: var(--panel);
        border-radius: var(--radius);
        padding: 20px 22px;
      }
      .lane-tag {
        display: inline-block;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 999px;
        margin-bottom: 16px;
      }
      .lane-tag.admin { color: #bcd0ff; background: rgba(43, 99, 240, 0.16); border: 1px solid rgba(43, 99, 240, 0.3); }
      .lane-tag.user { color: #b9ecfb; background: rgba(63, 200, 245, 0.14); border: 1px solid rgba(63, 200, 245, 0.28); }
      .chips { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
      .chip {
        display: inline-flex;
        flex-direction: column;
        gap: 2px;
        background: rgba(10, 16, 32, 0.6);
        border: 1px solid var(--brd-2);
        border-radius: 11px;
        padding: 10px 14px;
        font-weight: 600;
        font-size: 0.92rem;
      }
      .chip small { font-weight: 500; font-size: 0.72rem; color: var(--muted-2); }
      .chip.accent { border-color: rgba(63, 200, 245, 0.45); background: rgba(63, 200, 245, 0.08); }
      .chip.repo { border-color: rgba(43, 99, 240, 0.5); background: linear-gradient(135deg, rgba(63, 200, 245, 0.1), rgba(43, 99, 240, 0.14)); }
      .sep { width: 22px; height: 2px; border-radius: 2px; background: linear-gradient(90deg, var(--cyan), var(--blue)); opacity: 0.6; flex: none; }
      .flow-note { margin-top: 22px; color: var(--muted); font-size: 0.95rem; max-width: 74ch; }
      .flow-note strong { color: var(--text); font-weight: 650; }

      /* ── compare ── */
      .table-wrap { margin-top: 34px; overflow-x: auto; border: 1px solid var(--brd); border-radius: var(--radius); }
      table.compare { width: 100%; border-collapse: collapse; min-width: 640px; }
      .compare th, .compare td { padding: 14px 16px; text-align: center; border-bottom: 1px solid var(--brd); }
      .compare thead th { font-size: 0.9rem; font-weight: 700; color: var(--muted); background: rgba(255, 255, 255, 0.02); position: relative; }
      .compare th.cap, .compare td.cap { text-align: left; font-weight: 600; color: var(--text); }
      .compare td.cap { color: var(--muted); font-weight: 500; }
      .compare th small { display: block; font-size: 0.66rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--cyan); }
      .compare .ours { background: linear-gradient(180deg, rgba(63, 200, 245, 0.09), rgba(43, 99, 240, 0.05)); color: var(--text); }
      .compare thead th.ours { color: var(--text); }
      .compare tbody tr:last-child td { border-bottom: none; }

      .mark { display: inline-grid; place-items: center; width: 24px; height: 24px; border-radius: 7px; font-size: 0; }
      .mark::before { font-size: 13px; font-weight: 800; }
      .mark.yes { background: rgba(87, 214, 168, 0.15); }
      .mark.yes::before { content: '✓'; color: var(--ok); }
      .mark.partial { background: rgba(242, 193, 78, 0.14); }
      .mark.partial::before { content: '~'; color: var(--warn); }
      .mark.no { background: rgba(125, 139, 176, 0.14); }
      .mark.no::before { content: '–'; color: var(--no); }
      .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
      .legend { display: flex; align-items: center; gap: 8px 18px; flex-wrap: wrap; margin-top: 16px; color: var(--muted); font-size: 0.86rem; }
      .legend .mark { margin-right: -4px; }

      /* ── roadmap ── */
      .timeline { list-style: none; padding: 0; margin: 38px 0 0; display: grid; gap: 10px; }
      .timeline li {
        display: grid;
        grid-template-columns: 58px 1fr auto;
        align-items: center;
        gap: 16px;
        padding: 15px 18px;
        border: 1px solid var(--brd);
        background: var(--panel);
        border-radius: 12px;
      }
      .timeline .ms-id { font-weight: 800; color: var(--muted-2); font-size: 1.02rem; }
      .timeline .ms-label { color: var(--muted); font-size: 0.98rem; }
      .timeline li.here {
        border-color: rgba(63, 200, 245, 0.5);
        background: linear-gradient(135deg, rgba(63, 200, 245, 0.1), rgba(43, 99, 240, 0.08));
      }
      .timeline li.here .ms-id { color: var(--cyan); }
      .timeline li.here .ms-label { color: var(--text); font-weight: 600; }
      .ms-here { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #041027; background: var(--grad); padding: 4px 10px; border-radius: 999px; }
      .section-foot { margin-top: 20px; color: var(--muted); }
      .section-foot a, .flow-note a { color: var(--cyan); }

      /* ── open / honest ── */
      .open-card {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 28px;
        align-items: start;
        border: 1px solid var(--brd);
        border-radius: 22px;
        padding: clamp(26px, 4vw, 44px);
        background:
          radial-gradient(600px 300px at 90% 0%, rgba(43, 99, 240, 0.14), transparent 65%),
          var(--panel);
      }
      .open-card h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; }
      .note {
        border: 1px solid rgba(63, 200, 245, 0.28);
        background: rgba(63, 200, 245, 0.06);
        border-radius: 14px;
        padding: 22px;
      }
      .note h3 { font-size: 1.02rem; color: var(--cyan); margin-bottom: 10px; }
      .note p { margin: 0; color: var(--muted); font-size: 0.94rem; }
      .note a { color: var(--cyan); }
      .note strong { color: var(--text); }

      /* ── cta ── */
      .cta {
        max-width: var(--maxw);
        margin: clamp(64px, 10vw, 120px) auto 0;
        padding: clamp(40px, 6vw, 68px) var(--pad);
        text-align: center;
      }
      .cta h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; }
      .cta p { color: var(--muted); margin: 14px 0 0; font-size: 1.08rem; }
      .cta .hero-cta { justify-content: center; margin-top: 30px; }

      /* ── footer ── */
      .footer {
        max-width: var(--maxw);
        margin: clamp(48px, 8vw, 96px) auto 0;
        padding: 34px var(--pad) 48px;
        border-top: 1px solid var(--brd);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 18px 28px;
      }
      .foot-brand { display: inline-flex; align-items: center; gap: 10px; }
      .foot-brand .brand-mark { width: 18px; height: 30px; }
      .foot-links { display: flex; flex-wrap: wrap; gap: 8px 22px; margin-left: auto; }
      .foot-links a { color: var(--muted); text-decoration: none; font-size: 0.92rem; transition: color 0.15s; }
      .foot-links a:hover { color: var(--cyan); }
      .foot-fine { flex-basis: 100%; margin: 6px 0 0; color: var(--muted-2); font-size: 0.84rem; }

      /* ── responsive ── */
      @media (max-width: 900px) {
        .hero { grid-template-columns: 1fr; }
        .hero-art { order: -1; min-height: 240px; }
        .tag-a { left: 2%; }
        .tag-b { right: 2%; }
        .why-grid { grid-template-columns: 1fr; }
        .cards { grid-template-columns: 1fr 1fr; }
        .open-card { grid-template-columns: 1fr; }
      }
      @media (max-width: 620px) {
        .nav-links { gap: 14px; }
        .nav-links > a:not(.btn) { display: none; }
        .cards { grid-template-columns: 1fr; }
        .timeline li { grid-template-columns: 44px 1fr; }
        .timeline .ms-here { grid-column: 2; justify-self: start; }
        .sep { display: none; }
        .chips { gap: 8px; }
      }

      @media (prefers-reduced-motion: reduce) {
        * { animation: none !important; scroll-behavior: auto; }
      }
    </style>
  </body>
</html>
