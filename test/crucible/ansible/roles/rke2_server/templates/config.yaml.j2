# RKE2 server config — generated by ansible (crucible).
token: "{{ rke2_token }}"
{% if inventory_hostname != groups['masters'][0] %}
server: https://{{ first_master_private_ip }}:9345
{% endif %}
# Cluster traffic rides the private network.
node-ip: {{ private_ip }}
advertise-address: {{ private_ip }}
# Pin flannel's VXLAN to the private NIC (detected in the common role) — the
# public 8472/udp is firewall-blocked and the public 1500 MTU oversizes the
# overlay for the 1450 private path. Without this, cross-node pod traffic (and
# thus Ceph mon quorum) fails.
flannel-iface: {{ private_iface }}
tls-san:
{% for h in groups['masters'] %}
  - {{ hostvars[h].ansible_host }}
  - {{ hostvars[h].private_ip }}
{% endfor %}
node-label:
  # Custom prefix on purpose: kubelets may not self-assign node-role.kubernetes.io/*.
  - crystalbackup.io/node-role=master
write-kubeconfig-mode: "0640"
