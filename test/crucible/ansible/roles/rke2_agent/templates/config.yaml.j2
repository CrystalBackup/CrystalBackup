# RKE2 agent config — generated by ansible (crucible).
token: "{{ rke2_token }}"
server: https://{{ first_master_private_ip }}:9345
node-ip: {{ private_ip }}
node-label:
  - crystalbackup.io/node-role=worker
  # Longhorn only creates disks on labeled nodes (see deploy/manifests/longhorn-values.yaml)
  - node.longhorn.io/create-default-disk=true
