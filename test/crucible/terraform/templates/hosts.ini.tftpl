# Generated by terraform — DO NOT EDIT, DO NOT COMMIT (contains the RKE2 token).
[masters]
%{ for m in masters ~}
${m.name} ansible_host=${m.public_ip} private_ip=${m.private_ip} private_mac=${m.private_mac}
%{ endfor ~}

[workers]
%{ for w in workers ~}
${w.name} ansible_host=${w.public_ip} private_ip=${w.private_ip} private_mac=${w.private_mac}
%{ endfor ~}

[k8s:children]
masters
workers

[all:vars]
ansible_user=root
rke2_token=${rke2_token}
rke2_channel=${rke2_channel}
rke2_version=${rke2_version}
first_master_private_ip=${masters[0].private_ip}
first_master_public_ip=${masters[0].public_ip}
