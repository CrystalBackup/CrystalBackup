# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include files consumed by //go:embed. These are Go SOURCE as far as the compiler is
# concerned — a missing one fails the build with "pattern <file>: no matching files found" —
# but the allowlist above only re-includes *.go, so an embedded non-Go file is invisible here
# while building fine everywhere else. Add every new embed target to this list.
!internal/sanitize/rules.yaml
